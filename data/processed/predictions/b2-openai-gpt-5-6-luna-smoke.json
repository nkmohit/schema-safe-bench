        "raw_output": "WITH carcinogenic AS (\n  SELECT DISTINCT molecule_id\n  FROM molecule\n  WHERE LOWER(label) LIKE '%carcinogenic%'\n),\ncounts AS (\n  SELECT\n    COUNT(*) AS total,\n    SUM(CASE WHEN NOT EXISTS (\n      SELECT 1\n      FROM atom\n      WHERE atom.molecule_id = carcinogenic.molecule_id\n        AND LOWER(element) = 'f'\n    ) THEN 1 ELSE 0 END) AS without_fluorine\n  FROM carcinogenic\n)\nSELECT 100.0 * without_fluorine / NULLIF(total, 0) AS percentage\nFROM counts;",
