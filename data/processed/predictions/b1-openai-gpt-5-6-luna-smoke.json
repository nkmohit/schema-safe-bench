        "raw_output": "WITH target AS (\n  SELECT d.client_id, l.account_id\n  FROM loan l\n  JOIN disp d ON d.account_id = l.account_id\n  WHERE l.date = '1993-07-05'\n  ORDER BY l.date, l.loan_id\n  LIMIT 1\n),\nbalances AS (\n  SELECT\n    t.client_id,\n    SUM(CASE WHEN tr.date = '1993-03-22' THEN tr.amount ELSE 0 END) AS start_balance,\n    SUM(CASE WHEN tr.date = '1998-12-27' THEN tr.amount ELSE 0 END) AS end_balance\n  FROM target t\n  JOIN disp d ON d.client_id = t.client_id\n  JOIN account a ON a.account_id = d.account_id\n  JOIN \"order\" tr ON tr.account_id = a.account_id\n  GROUP BY t.client_id\n)\nSELECT (end_balance - start_balance) * 100.0 / NULLIF(start_balance, 0) AS increase_rate\nFROM balances;",
